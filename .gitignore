# ==========================================
# Cozy AR Companion (Luma) GitIgnore Rules
# ==========================================

# macOS System Files
.DS_Store
.AppleDouble
.LSOverride
Icon


# Windows System Files
Thumbs.db
ehthumbs.db
Desktop.ini


# Editors / IDEs
.vscode/
.idea/
*.suo
*.user
*.userprefs
*.sln
*.csproj
*.unityproj


# ==========================================
# Frontend (Unity) Build & Cache Outputs
# ==========================================
frontend/[Ll]ibrary/
frontend/[Tt]emp/
frontend/[Oo]bj/
frontend/[Bb]uild/
frontend/[Bb]uilds/
frontend/[Ll]ogs/
frontend/[Mm]emoryCaptures/
frontend/UserSettings/
frontend/CrashDumps/

# Generated asset overrides / dynamic setups
frontend/Assets/Materials/LumaBackgroundGradient.png
frontend/Assets/Materials/LumaBackgroundGradient.png.meta

# Autogenerated VS/Mono/Rider project files
frontend/*.csproj
frontend/*.unityproj
frontend/*.sln
frontend/*.suo
frontend/*.user
frontend/*.userprefs
frontend/*.pidb
frontend/*.booproj
frontend/*.svd
frontend/*.pdb
frontend/*.opendb
frontend/*.db

# Unity Asset Store cache (imported packages)
frontend/Assets/AssetStoreTools*


# ==========================================
# Backend (Node.js) Dependencies & Environment
# ==========================================
backend/node_modules/
backend/.env
backend/.env.local
backend/.env.development.local
backend/.env.test.local
backend/.env.production.local

# Logs
backend/logs
backend/*.log
backend/npm-debug.log*
backend/yarn-debug.log*
backend/yarn-error.log*
backend/pnpm-debug.log*
